<section class="max-w-2xl mx-auto bg-white rounded-lg shadow-md overflow-hidden">
  <div
    class="bg-slate-50 border-b border-slate-200 px-6 py-4 flex flex-col sm:flex-row justify-between sm:items-center gap-4">
    <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-3">
      <i class="bi bi-book text-indigo-500"></i>
      {{book.title}}
    </h2>
    <span
      class="bg-indigo-100 text-indigo-800 px-3 py-1 rounded-full text-sm font-semibold whitespace-nowrap self-start sm:self-auto">ID:
      {{book.id}}</span>
  </div>

  <div class="p-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
      <div class="flex flex-col">
        <span class="text-sm text-slate-500 font-medium mb-1"><i class="bi bi-person-fill text-slate-400 mr-1"></i>
          Autor</span>
        <span class="text-lg text-slate-800">{{book.author}}</span>
      </div>

      <div class="flex flex-col">
        <span class="text-sm text-slate-500 font-medium mb-1"><i class="bi bi-tags-fill text-slate-400 mr-1"></i>
          Gênero</span>
        <span class="text-lg text-slate-800">
          <span class="bg-slate-100 text-slate-700 px-3 py-1 rounded-full text-sm">{{book.genre}}</span>
        </span>
      </div>

      <div class="flex flex-col">
        <span class="text-sm text-slate-500 font-medium mb-1"><i
            class="bi bi-currency-dollar text-emerald-500 mr-1"></i> Preço</span>
        <span class="text-2xl font-bold text-emerald-600">{{currency book.price}}</span>
      </div>

      <div class="flex flex-col">
        <span class="text-sm text-slate-500 font-medium mb-1"><i class="bi bi-box-seam-fill text-slate-400 mr-1"></i>
          Estoque</span>
        <span class="text-lg text-slate-800">
          {{#if book.stock}}
          <span class="text-emerald-600 font-semibold">{{book.stock}} unidades</span>
          {{else}}
          <span class="text-red-500 font-bold">Esgotado</span>
          {{/if}}
        </span>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-3 pt-6 border-t border-slate-100">
      <a class="bg-amber-500 hover:bg-amber-600 text-white sm:flex-1 text-center px-4 py-2.5 rounded-md font-medium transition-colors flex justify-center items-center gap-2 shadow-sm"
        href="/livros/{{book.id}}/editar">
        <i class="bi bi-pencil-square"></i> Editar
      </a>
      <form class="inline sm:flex-1 m-0" action="/livros/{{book.id}}?_method=DELETE" method="POST">
        <button type="submit"
          class="bg-red-500 hover:bg-red-600 text-white w-full text-center px-4 py-2.5 rounded-md font-medium transition-colors flex justify-center items-center gap-2 shadow-sm h-full border-0 cursor-pointer">
          <i class="bi bi-trash-fill"></i> Excluir
        </button>
      </form>
      <a class="bg-slate-200 hover:bg-slate-300 text-slate-700 sm:flex-1 text-center px-4 py-2.5 rounded-md font-medium transition-colors flex justify-center items-center gap-2 shadow-sm"
        href="/livros">
        <i class="bi bi-arrow-left"></i> Voltar
      </a>
    </div>
  </div>
</section>