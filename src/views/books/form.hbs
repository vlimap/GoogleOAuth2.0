<section class="max-w-2xl mx-auto bg-white rounded-lg shadow-md p-6 sm:p-8">
  <div class="border-b border-slate-200 pb-4 mb-6">
    <h2 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
      <i class="bi bi-journal-text text-indigo-500"></i>
      {{formTitle}}
    </h2>
  </div>

  <form action="{{formAction}}" method="{{method}}" class="space-y-6">
    <div class="space-y-2">
      <label for="title" class="block text-sm font-semibold text-slate-700">Título</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <i class="bi bi-card-heading text-slate-400"></i>
        </div>
        <input id="title" name="title" type="text" value="{{book.title}}" required
          class="pl-10 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 shadow-sm transition-colors"
          placeholder="Nome do livro" />
      </div>
    </div>

    <div class="space-y-2">
      <label for="author" class="block text-sm font-semibold text-slate-700">Autor</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <i class="bi bi-person text-slate-400"></i>
        </div>
        <input id="author" name="author" type="text" value="{{book.author}}" required
          class="pl-10 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 shadow-sm transition-colors"
          placeholder="Nome do autor" />
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div class="space-y-2">
        <label for="genre" class="block text-sm font-semibold text-slate-700">Gênero</label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <i class="bi bi-tags text-slate-400"></i>
          </div>
          <input id="genre" name="genre" type="text" value="{{book.genre}}" required
            class="pl-10 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 shadow-sm transition-colors"
            placeholder="Ficção, Romance..." />
        </div>
      </div>

      <div class="space-y-2">
        <label for="price" class="block text-sm font-semibold text-slate-700">Preço (R$)</label>
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <i class="bi bi-currency-dollar text-slate-400"></i>
          </div>
          <input id="price" name="price" type="number" step="0.01" min="0" value="{{book.price}}" required
            class="pl-10 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 shadow-sm transition-colors"
            placeholder="0.00" />
        </div>
      </div>
    </div>

    <div class="space-y-2">
      <label for="stock" class="block text-sm font-semibold text-slate-700">Estoque</label>
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <i class="bi bi-box-seam text-slate-400"></i>
        </div>
        <input id="stock" name="stock" type="number" min="0" value="{{book.stock}}" required
          class="pl-10 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 shadow-sm transition-colors"
          placeholder="Quantidade" />
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 pt-4 border-t border-slate-200 mt-8">
      <button type="submit"
        class="bg-indigo-600 hover:bg-indigo-700 text-white w-full sm:w-auto px-6 py-2.5 rounded-md font-medium transition-colors flex justify-center items-center gap-2 shadow-sm order-1 sm:order-2 border-0 cursor-pointer">
        <i class="bi bi-check-circle"></i> Salvar
      </button>
      <a href="/livros"
        class="bg-white hover:bg-slate-50 text-slate-700 border border-slate-300 w-full sm:w-auto px-6 py-2.5 rounded-md font-medium transition-colors flex justify-center items-center gap-2 shadow-sm order-2 sm:order-1">
        <i class="bi bi-x-circle"></i> Cancelar
      </a>
    </div>
  </form>
</section>