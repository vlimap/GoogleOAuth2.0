<section class="bg-white rounded-lg shadow-md p-6">
  <div class="flex flex-col sm:flex-row justify-between items-center mb-6 gap-4">
    <h2 class="text-2xl font-bold text-slate-800">Catálogo de livros</h2>
    <a class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-md font-medium transition-colors flex items-center justify-center gap-2 w-full sm:w-auto shadow-sm"
      href="/livros/novo">
      <i class="bi bi-plus-lg"></i> Cadastrar livro
    </a>
  </div>

  {{#if books.length}}
  <div class="overflow-x-auto rounded-lg border border-slate-200">
    <table class="w-full text-left text-slate-700">
      <thead class="bg-slate-50 text-slate-600 border-b border-slate-200">
        <tr>
          <th class="px-4 py-3 font-semibold whitespace-nowrap">ID</th>
          <th class="px-4 py-3 font-semibold whitespace-nowrap">Título</th>
          <th class="px-4 py-3 font-semibold whitespace-nowrap">Autor</th>
          <th class="px-4 py-3 font-semibold whitespace-nowrap">Gênero</th>
          <th class="px-4 py-3 font-semibold whitespace-nowrap">Preço</th>
          <th class="px-4 py-3 font-semibold whitespace-nowrap text-center">Estoque</th>
          <th class="px-4 py-3 font-semibold whitespace-nowrap text-center">Ações</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-200">
        {{#each books}}
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="px-4 py-3 text-slate-500 whitespace-nowrap">{{this.id}}</td>
          <td class="px-4 py-3 font-medium text-slate-800 whitespace-nowrap">{{this.title}}</td>
          <td class="px-4 py-3 whitespace-nowrap">{{this.author}}</td>
          <td class="px-4 py-3 whitespace-nowrap">
            <span class="bg-slate-100 text-slate-600 px-2 py-1 rounded-full text-xs font-medium">{{this.genre}}</span>
          </td>
          <td class="px-4 py-3 font-medium text-emerald-600 whitespace-nowrap">{{currency this.price}}</td>
          <td class="px-4 py-3 text-center whitespace-nowrap">
            {{#if this.stock}}
            <span class="bg-emerald-100 text-emerald-700 px-2 py-1 rounded-full text-xs font-bold">{{this.stock}}</span>
            {{else}}
            <span class="bg-red-100 text-red-700 px-2 py-1 rounded-full text-xs font-bold">0</span>
            {{/if}}
          </td>
          <td class="px-4 py-3 whitespace-nowrap">
            <div class="flex items-center justify-center gap-2">
              <a href="/livros/{{this.id}}" class="text-indigo-600 hover:text-indigo-800 transition-colors p-1"
                title="Ver">
                <i class="bi bi-eye-fill text-lg"></i>
              </a>
              <a href="/livros/{{this.id}}/editar" class="text-amber-500 hover:text-amber-700 transition-colors p-1"
                title="Editar">
                <i class="bi bi-pencil-square text-lg"></i>
              </a>
              <form class="inline m-0" action="/livros/{{this.id}}?_method=DELETE" method="POST">
                <button type="submit"
                  class="text-red-500 hover:text-red-700 transition-colors p-1 cursor-pointer bg-transparent border-0"
                  title="Excluir">
                  <i class="bi bi-trash-fill text-lg"></i>
                </button>
              </form>
            </div>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{else}}
  <div class="text-center py-12 bg-slate-50 rounded-lg border border-dashed border-slate-300">
    <i class="bi bi-journal-x text-4xl text-slate-400 mb-3 block"></i>
    <p class="text-slate-500 text-lg">Não há livros cadastrados.</p>
    <a href="/livros/novo" class="text-indigo-600 hover:underline mt-2 inline-block">Cadastre o primeiro!</a>
  </div>
  {{/if}}
</section>